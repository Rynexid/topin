{
  "name": "topin",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "cd server && bun run dev",
    "dev:client": "cd client && bun run dev",
    "build": "bun run build:server && bun run build:client",
    "build:server": "cd server && bun run build",
    "build:client": "cd client && bun run build",
    "db:generate": "cd server && bunx prisma generate",
    "db:push": "cd server && bunx prisma db push",
    "db:migrate": "cd server && bunx prisma migrate dev",
    "db:seed": "cd server && bun run seed",
    "lint": "bun run lint:server && bun run lint:client",
    "lint:server": "cd server && bun run lint",
    "lint:client": "cd client && bun run lint",
    "typecheck": "bun run typecheck:server && bun run typecheck:client",
    "typecheck:server": "cd server && bun run typecheck",
    "typecheck:client": "cd client && bun run typecheck"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
